from sklearn.preprocessing import LabelEncoder

cat_cols = [
    'client_type',
    'gender',
    'country',
    'region',
    'acquisition_purpose',
    'loan_applied',
    'referral_channel'
]

for col in cat_cols:
    le = LabelEncoder()
    clients_ml[col] = le.fit_transform(clients_ml[col].astype(str))
